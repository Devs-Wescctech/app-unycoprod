modules = ["nodejs-20", "python-3.11", "postgresql-16"]
[agent]
expertMode = true

[nix]
channel = "stable-25_05"
packages = ["unzip"]

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "App Server"

[[workflows.workflow]]
name = "App Server"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "npm run build && NODE_ENV=production PORT=5000 node server/index.js"
waitForPort = 5000

[workflows.workflow.metadata]
outputType = "webview"

[[ports]]
localPort = 3001
externalPort = 3000

[[ports]]
localPort = 5000
externalPort = 80

[[ports]]
localPort = 5001
externalPort = 3001

[deployment]
deploymentTarget = "autoscale"
build = ["sh", "-c", "npm install --production=false && npm run build"]
run = ["sh", "-c", "NODE_ENV=production node server/index.js"]

[userenv]

[userenv.shared]
VITE_TOTVS_API_TOKEN = "${TOTVS_API_TOKEN}"

[userenv.production]
NODE_ENV = "production"

[postMerge]
path = "scripts/post-merge.sh"
timeoutMs = 180000
